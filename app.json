{
  "expo": {
    "name": "mobile_pet",
    "slug": "mobile_pet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/pet.svg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#573F94",
          "dark": {
            "backgroundColor": "#573F94"
          }
        }
      ]
    ]
  }
}
